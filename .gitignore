# autogenerated:
# include/reloc_data.h is the committed selector shim; the per-version
# headers it #includes are autogenerated and gitignored.
include/reloc_data.us.h
include/reloc_data.jp.h
symbols/reloc_data_symbols.*

# relocData asset data: regenerated by the build into build/src/relocData/.
# Users CAN drop a .png override into src/relocData/<FileName>/ to replace
# the auto-extracted texture - the build will use it instead. PNGs and .inc.c
# files in src/relocData/ are gitignored so they don't accidentally land in
# version control; the .sprite.c / .data.c / .dobjdesc.c block files and
# .manifest / .spritelist files ARE committed (they describe asset structure).
src/relocData/**/*.inc.c
src/relocData/**/*.bin